{
  "name": "@veloze/session",
  "version": "1.0.0",
  "description": "session store",
  "keywords": [],
  "homepage": "https://github.com/commenthol/veloze-session",
  "repository": {
    "type": "git",
    "url": "https://github.com/commenthol/veloze-session.git"
  },
  "license": "MIT",
  "author": "commenthol <commenthol@gmail.com>",
  "sideEffects": false,
  "type": "module",
  "imports": {
    "#*": {
      "default": "./src/*"
    }
  },
  "main": "src/index.js",
  "types": "types/index.d.ts",
  "files": [
    "src",
    "types"
  ],
  "scripts": {
    "all": "npm-run-all lint c8 types",
    "changelog": "conv-changelog -o",
    "ci": "CI=true npm-run-all lint c8 types",
    "c8": "c8 -r lcov -r text npm t",
    "docs": "markedpp -s -i README.md",
    "dc": "docker compose --env-file .env -f ./scripts/docker-compose.yaml",
    "dc:down": "npm run dc -- down",
    "dc:up": "npm run dc -- up -d",
    "lint": "eslint .",
    "test": "mocha",
    "types": "rm -rf types; tsc && cp -r src/*.d.ts types/"
  },
  "mocha": {
    "color": true,
    "recursive": true,
    "timeout": 2000
  },
  "dependencies": {
    "debug-level": "^4.1.1",
    "veloze": "^1.5.2"
  },
  "devDependencies": {
    "@commenthol/dotconfig": "^1.5.3",
    "@types/node": "^25.5.0",
    "c8": "^11.0.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "ioredis": "^5.10.1",
    "mocha": "^11.7.5",
    "mongodb": "^7.1.0",
    "npm-run-all2": "^8.0.4",
    "pg": "^8.20.0",
    "sequelize": "^6.37.8",
    "sinon": "^21.0.3",
    "supertest": "^7.2.2",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {},
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
